# Images
CONTEXTGATE_IMAGE=contextgate:local
CONTEXTGATE_BUILD_CONTEXT=.
CONTEXTGATE_POSTGRES_IMAGE=postgres:18-alpine
CONTEXTGATE_REDIS_IMAGE=redis:8-alpine
CONTEXTGATE_QDRANT_IMAGE=qdrant/qdrant:v1.18.2

# Service ports. Docker Compose uses the same port inside the container and on your machine.
CONTEXTGATE_API_PORT=8000
CONTEXTGATE_CHAINLIT_PORT=8001
CONTEXTGATE_MLFLOW_PORT=5000
CONTEXTGATE_QDRANT_PORT=6333
CONTEXTGATE_POSTGRES_PORT=5432
CONTEXTGATE_REDIS_PORT=6379

# Docker Compose internal service names and bind hosts.
CONTEXTGATE_API_SERVICE=api
CONTEXTGATE_API_BIND_HOST=0.0.0.0
CONTEXTGATE_CHAINLIT_BIND_HOST=0.0.0.0
CONTEXTGATE_MLFLOW_SERVICE=mlflow
CONTEXTGATE_MLFLOW_BIND_HOST=0.0.0.0
CONTEXTGATE_MLFLOW_ARTIFACT_ROOT=/mlartifacts
CONTEXTGATE_MLFLOW_REGISTRY_STORE_URI=
CONTEXTGATE_MLFLOW_WORKERS=1
CONTEXTGATE_MLFLOW_ALLOWED_HOSTS=localhost,localhost:5000,127.0.0.1,127.0.0.1:5000,mlflow,mlflow:5000,host.docker.internal,host.docker.internal:5000
CONTEXTGATE_MLFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8001,http://127.0.0.1:8001
CONTEXTGATE_MLFLOW_SUPPRESS_UPSTREAM_WARNINGS=true
CONTEXTGATE_QDRANT_SERVICE=qdrant
CONTEXTGATE_POSTGRES_SERVICE=postgres
CONTEXTGATE_REDIS_SERVICE=redis
CONTEXTGATE_HF_HOME=/models

# Postgres databases and credentials
CONTEXTGATE_DATABASE_BACKEND=postgres
CONTEXTGATE_DATABASE_NAME=contextgate
CONTEXTGATE_DATABASE_USER=contextgate
CONTEXTGATE_DATABASE_PASSWORD=contextgate-dev-password
CONTEXTGATE_MLFLOW_DATABASE_NAME=mlflow

# Redis
CONTEXTGATE_REDIS_PASSWORD=contextgate-redis-dev-password

# API/auth
CONTEXTGATE_ENVIRONMENT=development
CONTEXTGATE_API_KEY=contextgate-dev-key
CONTEXTGATE_AUTH_ENABLED=true
CONTEXTGATE_RATE_LIMIT_PER_MINUTE=120

# Local non-Docker defaults used by uv run ctxgate/uvicorn.
CONTEXTGATE_SQLITE_PATH=./.contextgate/contextgate.db
CONTEXTGATE_QDRANT_URL=
CONTEXTGATE_QDRANT_LOCAL_PATH=./.contextgate/qdrant
CONTEXTGATE_MLFLOW_TRACKING_URI=./mlruns
CONTEXTGATE_UI_API_URL=http://localhost:8000

# Retrieval / Qdrant
CONTEXTGATE_EMBEDDING_BACKEND=fastembed
CONTEXTGATE_DENSE_DIMENSION=384
CONTEXTGATE_LATE_DIMENSION=96
CONTEXTGATE_LATE_INTERACTION_LANGUAGES=en
CONTEXTGATE_QDRANT_STRICT_MODE=true
# JSON map of custom metadata filters to Qdrant payload index types.
CONTEXTGATE_INDEXED_METADATA_FIELDS={}
CONTEXTGATE_POLICIES_PATH=configs/policies.yaml

# Generation provider (optional)
CONTEXTGATE_LLM_MODEL=
CONTEXTGATE_LLM_API_BASE=
CONTEXTGATE_LLM_API_KEY=

# Worker
CONTEXTGATE_WORKER_LOG_LEVEL=INFO
CONTEXTGATE_WORKER_CONCURRENCY=2
